# --- Funcionarios --- 
  #  razaoSocial: string;
  #  cnpj: string;
  #  cnae: string;
  #  totalFuncionarios: number;
  #  data_criacao: Date;
  #  data_atualizacao: Date;

### Criar Funcionario

POST http://localhost:3000/funcionarios
Content-Type: application/json

{
    "matricula": "12345",
    "nome": "João Silva",
    "dataAdmissao": "2024-01-15",
    "status": "ativo",
    "id_cargo": 1,
    "id_setor": 2
}

### Listar Funcionarios
GET http://localhost:3000/funcionarios

### Atualizar Funcionario
PUT http://localhost:3000/funcionarios/1
Content-Type: application/json

{
    "matricula": "12345",
    "nome": "João Silva",
    "dataAdmissao": "2024-02-15",
    "status": "ativo",
    "id_cargo": 2,
    "id_setor": 2
}

### Excluir Funcionario
DELETE http://localhost:3000/funcionarios/1

### Criar Empresa
POST http://localhost:3000/empresas
Content-Type: application/json

{
    "razaoSocial": "Empresa XYZ Ltda",
    "cnpj": "12.345.678/0001-99",
    "cnae": "6201-5/01",
    "totalFuncionarios": 100,
    "data_criacao": "2020-01-01",
    "data_atualizacao": "2024-01-01"
}

### Listar Empresas
GET  http://localhost:3000/empresas

### Atualizar Empresa
PUT http://localhost:3000/empresas/1
Content-Type: application/json

{
    "razaoSocial": "Empresa XYZ Ltda",
    "cnpj": "12.345.678/0001-90",
    "cnae": "6201-5/01",
    "totalFuncionarios": 150,
    "data_criacao": "2020-01-01",
    "data_atualizacao": "2024-01-01"
}

### Excluir Empresa
DELETE http://localhost:3000/empresas/1



