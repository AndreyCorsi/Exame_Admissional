Content-Type: application/json

{
    "nome": "Recursos Humanos",
    "descricao": "Setor responsável pela gestão de pessoas",
    "data_criacao": "2020-01-01",
    "data_atualizacao": "2024-01-01",
    "id_empresa": 2
}

