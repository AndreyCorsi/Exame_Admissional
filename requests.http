# --- Cargo --- 
  #  nome: string;
  #  codigoCBO: string;
  #  descricaoAtividades: string;
  #  id_setor: number;

### Criar Cargo
POST http://localhost:3000/cargos
Content-Type: application/json

{
    "nome": "Analista de Recursos Humanos",
    "codigoCBO": "1234-56",
    "descricaoAtividades": "Responsável por atividades de recrutamento e seleção",
    "id_setor": 2
}

### Listar Cargos
GET http://localhost:3000/cargos

### Atualizar Cargo

PUT http://localhost:3000/cargos/1
Content-Type: application/json

{
    "nome": "AAAAAA",
    "codigoCBO": "1234-56",
    "descricaoAtividades": "Responsável por atividades de recrutamento e seleção",
    "id_setor": 2
}

### Excluir Cargo
DELETE http://localhost:3000/cargos/1



### --- ASO ---
    # dataEmissao: Date;
    # tipoExame: TipoExame;
    # aptidao: ASOStatus;
    # restricao: string;
    # proximoASO: Date;
    # medicoResponsavel: string;
    # crmMedico: string;
    # data_criacao: Date;
    # id_funcionario: number;

### Criar ASO
POST http://localhost:3000/asos
Content-Type: application/json

{
    "dataEmissao": "2024-01-15",
    "tipoExame": "admissional",
    "aptidao": "apto",
    "restricao": "Nenhuma",
    "proximoASO": "2025-01-15",
    "medicoResponsavel": "Dr. Carlos Silva",
    "crmMedico": "12345-SP",
    "data_criacao": "2024-01-15",
    "id_funcionario": 1
}

### Listar ASOs
GET http://localhost:3000/asos

### Atualizar ASO
PUT http://localhost:3000/asos/1
Content-Type: application/json

{
    "dataEmissao": "2024-01-15",
    "tipoExame": "admissional",
    "aptidao": "apto",
    "restricao": "Nenhuma",
    "proximoASO": "2025-01-15",
    "medicoResponsavel": "Dr. Andre Silva",
    "crmMedico": "12345-SP",
    "data_criacao": "2024-01-15",
    "id_funcionario": 1
}

